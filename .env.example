# Screenshot API Configuration

# Cache directory (inside container: /data/cache)
CACHE_DIR=/data/cache

# Cache TTL in seconds (default: 3600 = 1 hour)
CACHE_TTL=3600

# SQLite database path for auth/rate limiting
AUTH_DB_PATH=/data/auth.db

# API server port
PORT=8500

# Max free-tier screenshots per day per IP
MAX_FREE_DAILY=100

# Admin key for managing API keys (POST /admin/keys)
ADMIN_KEY=change-me-in-production

# Cache cleanup interval in seconds (default: 1800 = 30 min)
CLEANUP_INTERVAL=1800
